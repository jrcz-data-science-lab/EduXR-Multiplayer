# Git LFS tracking for large binary files
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text

# Ensure text files have proper line endings
*.cpp text eol=lf
*.h text eol=lf
*.cs text eol=lf
*.ini text eol=lf
*.uplugin text eol=lf

# Binary files
*.dll binary
*.exe binary
*.pdb binary
*.lib binary
*.a binary
*.so binary
*.dylib binary

