# Unreal Engine Plugin - Ignore compiled and intermediate files

# Binaries folder - compiled DLLs
Binaries/

# Intermediate folder - build artifacts
Intermediate/

# Build artifacts
Build/
*.sln
*.suo
*.xcodeproj
*.xcworkspace

# Visual Studio files
.vs/
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa
*.ps1

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Unreal specific
DerivedDataCache/
Saved/

